      "context": "all",
      "category": "ultra",
      "minIntensity": "ultra"
    },
    {
      "name": "ultra_dependency_abbreviation",
      "pattern": "\\b(?:dependency|dependencies)\\b",
      "replacement": "dep",
      "replacementMap": {
        "dependency": "dep",
        "dependencies": "deps"
